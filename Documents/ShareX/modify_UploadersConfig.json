{{- /* chezmoi:modify-template */ -}}
{{- if .integration.bitwarden.enabled -}}
{{ $imgur_client := (bitwardenFields "item" "Sharex").imgur_client.value }}
{{ $imgur_secret := (bitwardenFields "item" "Sharex").imgur_secret.value }}
{{ $xbb_api_token := (bitwardenFields "item" "Sharex").xbb_api_token.value }}
{{- else if .integration.onepassword.enabled -}}
{{ $imgur_client := onepasswordRead "op://Personal/dotfiles/sharex_imgur_client" }}
{{ $imgur_secret := onepasswordRead "op://Personal/dotfiles/sharex_imgur_secret" }}
{{ $xbb_api_token := onepasswordRead "op://Personal/dotfiles/sharex_xbb" }}
{{ end -}}
{{- $ImgurInfo := dict
  "Client_ID" $imgur_client
  "Client_Secret" $imgur_secret
  "Token" nil
  "Proof" nil
-}}

{{- $CustomUploadersList := list (dict
  "Version" "14.1.0"
  "DestinationType" "ImageUploader, TextUploader, FileUploader"
  "RequestMethod" "POST"
  "RequestURL" "https://images.roxedus.net/upload"
  "Body" "MultipartFormData"
  "FileFormName" "upload"
  "URL" "{json:url}/raw"
  "ThumbnailURL" "{json:url}/raw"
  "DeletionURL" (nospace (cat "{json:url}/delete/" $xbb_api_token))
  "ErrorMessage" nil
  "Arguments" (dict
    "file" "{filename}"
    "text" "{input}"
    "token" $xbb_api_token
  )
)
-}}

{{ fromJson .chezmoi.stdin |
  setValueAtPath "ImgurOAuth2Info" $ImgurInfo |
  setValueAtPath "CustomUploadersList" $CustomUploadersList |
  setValueAtPath "CustomImageUploaderSelected" "0" |
  setValueAtPath "CustomTextUploaderSelected" "0" |
  setValueAtPath "CustomFileUploaderSelected" "0" |
  toPrettyJson
}}
